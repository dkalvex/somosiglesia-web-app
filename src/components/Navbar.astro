---
// Navbar component
---

<nav>
  <a href="#" class="nav-logo">
    <img
      id="nav-logo-img"
      src={`${import.meta.env.BASE_URL}imgs/logo-blanco.png`}
      data-logo-dark={`${import.meta.env.BASE_URL}imgs/logo-blanco.png`}
      data-logo-light={`${import.meta.env.BASE_URL}imgs/logo-negro.png`}
      alt="Somos Iglesia Medellín"
      class="nav-logo-img"
    />
  </a>

  <ul class="nav-links">
    <li><a href="#nosotros">Nosotros</a></li>
    <li><a href="#ministerios">Ministerios</a></li>
    <li><a href="#sermones">Sermones</a></li>
    <li><a href="#servicios">Servicios</a></li>
    <li><a href="#creemos">Creemos</a></li>
    <li><a href="#pasos">Conéctate</a></li>
    <li><a href="#donaciones">Donaciones</a></li>
  </ul>

  <a href="#servicios" class="nav-cta">Visítanos</a>

  <button class="theme-toggle" id="theme-toggle" aria-label="Cambiar modo" type="button">
    <svg class="icon-sun" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="12" cy="12" r="4"/><line x1="12" y1="2" x2="12" y2="4"/><line x1="12" y1="20" x2="12" y2="22"/>
      <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
      <line x1="2" y1="12" x2="4" y2="12"/><line x1="20" y1="12" x2="22" y2="12"/>
      <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
    </svg>
    <svg class="icon-moon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
    </svg>
  </button>

  <button class="nav-hamburger" id="hamburger" aria-label="Abrir menú">
    <span></span>
    <span></span>
    <span></span>
  </button>
</nav>

<style>
  .nav-logo-img {
    height: 140px;
    width: auto;
    display: block;
  }
  .theme-toggle {
    background: none;
    border: 1px solid var(--border-subtle);
    color: var(--text-secondary);
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    border-radius: 2px;
    transition: border-color 0.3s, color 0.3s;
    flex-shrink: 0;
  }
  .theme-toggle:hover {
    border-color: var(--border-strong);
    color: var(--text-primary);
  }
</style>

<div class="nav-mobile" id="mobile-nav">
  <a href="#nosotros">Nosotros</a>
  <a href="#ministerios">Ministerios</a>
  <a href="#sermones">Sermones</a>
  <a href="#servicios">Servicios</a>
  <a href="#creemos">Creemos</a>
  <a href="#pasos">Conéctate</a>
  <a href="#donaciones">Donaciones</a>
  <a href="#servicios" class="nav-cta" style="font-size:14px;">Visítanos</a>
</div>
