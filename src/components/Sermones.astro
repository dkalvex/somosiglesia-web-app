---
// Sermones component
---

<div id="sermones" style="background:#0d0b09;">
  <section>
    <div class="sermon-header fade-in">
      <div>
        <p class="section-eyebrow">Sermones Recientes</p>
        <h2 class="section-title">Cada mensaje,<br><em>para tu vida.</em></h2>
      </div>
      <a href="#" class="btn-ghost" style="white-space:nowrap;">Ver todos →</a>
    </div>

    <div class="sermons-grid fade-in">
      <div class="sermon-card">
        <img src="/imgs/extracted_0_serm_n_destacado.jpg" alt="Sermón destacado" class="sermon-thumb" />
        <div class="sermon-overlay">
          <div class="sermon-date">Más reciente · Domingo</div>
          <div class="sermon-title">Religión sin Relación: Demasiado Peligroso</div>
          <div class="sermon-pastor">Pr. Daniel Hermida</div>
        </div>
        <div class="play-btn">
          <svg width="14" height="16" fill="none" viewBox="0 0 14 16">
            <path d="M1 1l12 7-12 7V1z" stroke="#EAE6DD" stroke-width="1.5" stroke-linejoin="round"/>
          </svg>
        </div>
      </div>

      <div class="sermon-card">
        <img src="/imgs/extracted_1_serm_n.jpg" alt="Sermón" class="sermon-thumb" />
        <div class="sermon-overlay">
          <div class="sermon-date">Miércoles · En Casa</div>
          <div class="sermon-title">Lo Que Creer Realmente Significa</div>
          <div class="sermon-pastor">Pr. Daniel Hermida</div>
        </div>
        <div class="play-btn">
          <svg width="14" height="16" fill="none" viewBox="0 0 14 16">
            <path d="M1 1l12 7-12 7V1z" stroke="#EAE6DD" stroke-width="1.5" stroke-linejoin="round"/>
          </svg>
        </div>
      </div>

      <div class="sermon-card">
        <img src="/imgs/extracted_2_serm_n.jpg" alt="Sermón" class="sermon-thumb" />
        <div class="sermon-overlay">
          <div class="sermon-date">Domingo · Servicio</div>
          <div class="sermon-title">La Fe que Mueve Montañas</div>
          <div class="sermon-pastor">Pr. Daniel Hermida</div>
        </div>
        <div class="play-btn">
          <svg width="14" height="16" fill="none" viewBox="0 0 14 16">
            <path d="M1 1l12 7-12 7V1z" stroke="#EAE6DD" stroke-width="1.5" stroke-linejoin="round"/>
          </svg>
        </div>
      </div>

      <div class="sermon-card">
        <img src="/imgs/extracted_3_serm_n.jpg" alt="Sermón" class="sermon-thumb" />
        <div class="sermon-overlay">
          <div class="sermon-date">Miércoles · En Casa</div>
          <div class="sermon-title">El Arrepentimiento Genuino Produce Lágrimas</div>
          <div class="sermon-pastor">Pr. Daniel Hermida</div>
        </div>
        <div class="play-btn">
          <svg width="14" height="16" fill="none" viewBox="0 0 14 16">
            <path d="M1 1l12 7-12 7V1z" stroke="#EAE6DD" stroke-width="1.5" stroke-linejoin="round"/>
          </svg>
        </div>
      </div>
    </div>
  </section>
</div>
