---
// Pasos component
---

<div id="pasos" style="background:var(--surface-raised);">
  <section>
    <div class="pasos-layout fade-in">
      <div class="pasos-text">
        <p class="section-eyebrow">Da el Primer Paso</p>
        <h2 class="section-title">Conéctate<br><em>con nosotros.</em></h2>
        <div class="divider"></div>
        <p class="pasos-body">
          ¿Quieres visitarnos por primera vez? ¿Tienes preguntas sobre la fe? ¿Quieres unirte a un ministerio o grupo? Déjanos tus datos y alguien de nuestro equipo se pondrá en contacto contigo pronto.
        </p>
        <p class="pasos-body">
          No importa en qué punto del camino estés — hay un lugar para ti aquí. Somos familia.
        </p>
        <p class="pasos-verse">"Jesús Nombre Sobre Todo Nombre" — Filipenses 2:9</p>
      </div>
      <div class="pasos-form-wrap">
        <form class="pasos-form">
          <div class="form-group">
            <label for="nombre">Nombre completo</label>
            <input type="text" id="nombre" name="nombre" placeholder="Tu nombre" required />
          </div>
          <div class="form-group">
            <label for="email">Correo electrónico</label>
            <input type="email" id="email" name="email" placeholder="tu@correo.com" />
          </div>
          <div class="form-group">
            <label for="telefono">Teléfono</label>
            <input type="tel" id="telefono" name="telefono" placeholder="+57 300 000 0000" />
          </div>
          <div class="form-group">
            <label for="mensaje">¿Cómo podemos ayudarte?</label>
            <textarea id="mensaje" name="mensaje" rows="4" placeholder="Cuéntanos un poco sobre ti..."></textarea>
          </div>
          <button type="submit" class="btn-primary" style="width:100%;text-align:center;">
            Déjanos tus datos →
          </button>
        </form>
      </div>
    </div>
  </section>
</div>

<script>
  document.querySelector('.pasos-form').addEventListener('submit', function (e) {
    e.preventDefault();

    const nombre   = document.getElementById('nombre').value.trim();
    const email    = document.getElementById('email').value.trim();
    const telefono = document.getElementById('telefono').value.trim();
    const mensaje  = document.getElementById('mensaje').value.trim();

    let contactInfo = '';
    if (email && telefono) contactInfo = `Mi correo es ${email} y mi teléfono es ${telefono}.`;
    else if (email)        contactInfo = `Mi correo es ${email}.`;
    else if (telefono)     contactInfo = `Mi teléfono es ${telefono}.`;

    const parts = [
      `Hola! Soy ${nombre}, Los contacto desde la página web de Somos Iglesia.`,
      contactInfo || null,
      mensaje ? `Quería contarles: ${mensaje}` : null,
    ].filter(Boolean).join('\n\n');

    const url = `https://wa.me/573136924776?text=${encodeURIComponent(parts)}`;
    window.open(url, '_blank');
  });
</script>

<style>
  .pasos-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: start;
  }
  .pasos-body {
    font-size: 16px;
    line-height: 1.9;
    color: var(--cream-mid);
    margin-bottom: 24px;
  }
  .pasos-verse {
    font-size: 13px;
    color: var(--text-faint);
    font-style: italic;
    letter-spacing: 0.05em;
    margin-top: 8px;
  }
  .pasos-form-wrap {
    background: var(--surface-raised);
    border: 1px solid var(--border-subtle);
    padding: 48px;
  }
  .pasos-form {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }
  .form-group {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .form-group label {
    font-size: 11px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--brown-mid);
    font-weight: 400;
  }
  .form-group input,
  .form-group textarea {
    background: var(--surface-bg);
    border: 1px solid rgba(107,106,97,0.2);
    color: var(--text-primary);
    padding: 14px 16px;
    font-family: 'Outfit', sans-serif;
    font-size: 14px;
    font-weight: 300;
    outline: none;
    transition: border-color 0.3s;
    resize: vertical;
  }
  .form-group input::placeholder,
  .form-group textarea::placeholder {
    color: rgba(107,106,97,0.5);
  }
  .form-group input:focus,
  .form-group textarea:focus {
    border-color: rgba(202,198,195,0.5);
  }
  @media (max-width: 900px) {
    .pasos-layout {
      grid-template-columns: 1fr;
      gap: 48px;
    }
    .pasos-form-wrap { padding: 32px 24px; }
  }
</style>
