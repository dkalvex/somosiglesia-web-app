---
// Hero component
---

<div class="hero">
  <div class="hero-bg" aria-hidden="true"></div>
  <div class="hero-overlay" aria-hidden="true"></div>

  <div class="hero-content">
    <p class="hero-eyebrow">Bienvenido a</p>
    <h1 class="hero-title">
      Somos<br>
      <em>Iglesia</em>
    </h1>
    <p class="hero-subtitle">Medellín</p>
    <p class="hero-verse">"Venid en pos de mí, y os haré pescadores de hombres." — Mateo 4:19</p>
    <div class="hero-actions">
      <a href="#servicios" class="btn-primary">Visítanos</a>
      <a href="#nosotros" class="btn-ghost">Conoce más</a>
    </div>
  </div>

  <div class="scroll-indicator" aria-hidden="true">
    <div class="scroll-line"></div>
    <span>Scroll</span>
  </div>
</div>
